generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Stream {
  id          String     @id @default(uuid())
  type        StreamType
  url         String
  extractedId String
  title       String    @default("")
  sThumbnail  String    @default("")
  bThumbnail  String    @default("")
  active      Boolean    @default(true)
  userId      String
  User        User       @relation(fields: [userId], references: [id])
  Upvote      Upvote[]
}

model Upvote {
  id          String    @id @default(uuid())
  userId      String
  streamId    String
  Stream      Stream    @relation(fields: [streamId], references: [id])
  User        User      @relation(fields: [userId], references: [id])

  @@unique([userId, streamId])
}

model User {
  id        String      @id @default(uuid())
  email     String      @unique
  name      String
  provider  Provider
  Stream    Stream[]
  Upvote    Upvote[]
}

enum Provider {
  Google
}

enum StreamType {
  Youtube
  Spotify
}
